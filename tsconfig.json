{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "types": ["vite/client", "node"]
  },
  "include": ["framework/**/*", "tests/**/*", "vitest.config.ts", "tsup.config.ts"]
}
